# =============================================================================
# Autonomous GitOps & Auto-Remediation Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit a .env file with real secrets.
# All config follows 12-factor app principles (https://12factor.net/config).
# =============================================================================

# --- Kubernetes / Cluster ---
KUBECONFIG=~/.kube/config
CLUSTER_NAME=autosre-dev

# --- LLM Provider / Diagnoser ---
# Provider priority: NIM > Gemini > rule-based fallback (no key needed).
# NEVER commit real keys — use a secrets manager in production.

# NVIDIA NIM (recommended) — get key at https://build.nvidia.com
NIM_API_KEY=
NIM_MODEL=meta/llama-3.3-70b-instruct

# Google Gemini (legacy fallback — used only if NIM_API_KEY is not set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Shared LLM timeout (seconds). Default: 30.
LLM_TIMEOUT_SECONDS=30

# --- Diagnoser HTTP service ---
# Port the Python FastAPI diagnoser listens on.
DIAGNOSER_PORT=8001
DIAGNOSER_HOST=0.0.0.0
# URL the Go agent uses to reach the diagnoser (internal service URL in-cluster).
DIAGNOSER_ADDR=http://localhost:8001
# Timeout for the Go→Python HTTP call (should be > LLM_TIMEOUT_SECONDS). Default: 35s.
DIAGNOSER_TIMEOUT=35s

# --- Observability backends ---
# PROMETHEUS_URL=http://localhost:9090
#
# Loki log polling — set LOKI_ADDR to enable error-log signal ingestion.
# When empty, the Loki source is disabled (Alertmanager webhook + k8s events still work).
LOKI_ADDR=
# LOKI_ADDR=http://localhost:3100
LOKI_POLL_INTERVAL=30s
LOKI_TIMEOUT=10s
LOKI_QUERY={namespace=~".+"}

# --- Notifications (Prompt 6) ---
# Slack bot token (xoxb-...). Empty → Notify/RequestApproval degrade to log-only.
# NEVER commit a real token — use a secrets manager in production.
SLACK_BOT_TOKEN=
# Slack signing secret for verifying inbound /slack/interactions requests.
# Empty → all inbound requests are rejected (fail-closed).
SLACK_SIGNING_SECRET=
# Slack channel ID (e.g. C01234ABCD) for notifications and approval requests.
SLACK_CHANNEL_ID=
# PagerDuty Events API v2 routing key. Empty → PagerDuty escalations skipped.
PAGERDUTY_ROUTING_KEY=
# How long to wait for a human approval before timing out (fail-closed). Default: 30m.
NOTIFIER_APPROVAL_TIMEOUT=30m
# Per-call HTTP timeout for outbound Slack/PagerDuty sends. Default: 10s.
NOTIFIER_SEND_TIMEOUT=10s
# Max retries for failed outbound sends (exponential backoff). Default: 3.
NOTIFIER_MAX_RETRIES=3

# --- GitHub (future prompt) ---
# GITHUB_TOKEN=your-github-personal-access-token
# GITHUB_REPO=your-org/your-repo
# GITHUB_BRANCH=main

# --- ArgoCD (future prompt) ---
# ARGOCD_SERVER=argocd.your-domain.com
# ARGOCD_TOKEN=your-argocd-token

# --- Agent runtime ---
LOG_LEVEL=info
DRY_RUN=true
CONFIDENCE_THRESHOLD=0.85

# --- Kubernetes client ---
# Leave KUBECONFIG empty to use ~/.kube/config (standard kubectl default).
# KUBECONFIG=/path/to/kubeconfig
IN_CLUSTER=false        # set to "true" when running inside a pod

# --- Detection: HTTP server ---
WEBHOOK_ADDR=:8080      # address for POST /webhook/alertmanager and GET /incidents

# --- Detection: Correlator windows ---
CORRELATION_WINDOW=5m   # how long to group signals into the same incident
RESOLVE_WINDOW=10m      # close an incident after this long without new signals
DEDUP_WINDOW=1m         # suppress identical (resource+reason) signals within this window

# --- GitOps Remediation ---
# Path to the local clone of the GitOps config repository.
# The agent commits YAML changes here; ArgoCD syncs them to the cluster.
GITOPS_REPO_PATH=/path/to/local/gitops-repo

# Git commit author identity for automated remediation commits.
GIT_BOT_NAME=autosre-bot
GIT_BOT_EMAIL=autosre-bot@localhost

# Branch to commit remediation changes on. Default: main.
GIT_BRANCH=main

# When true (default), all remediation actions are dry-run only.
# The CLI --apply flag overrides this for manual one-shot actions.
REMEDIATION_DRY_RUN=true

# Multiplier for BumpMemoryLimit action. Default: 1.5 (150% of current limit).
MEMORY_BUMP_FACTOR=1.5

# Remote git URL to push commits to. REQUIRED for ArgoCD to see changes.
# Example (HTTPS): https://github.com/your-org/gitops-config.git
# Example (SSH):   git@github.com:your-org/gitops-config.git
# Leave empty to keep commits local only (ArgoCD will NOT sync them).
GIT_REMOTE_URL=

# HTTPS personal-access token for push authentication.
# Used when GIT_REMOTE_URL is an https:// URL.
# GitHub: create a token with 'repo' scope at https://github.com/settings/tokens
# NEVER commit a real token — mount as a Kubernetes Secret in production.
GIT_TOKEN=

# Path to a PEM-encoded SSH private key for push authentication.
# Used when GIT_REMOTE_URL is an ssh:// or git@ URL.
# Example: /etc/autosre/git-ssh/id_ed25519
# Mount as a Kubernetes Secret volume in production.
GIT_SSH_KEY_PATH=

# --- Verifier (Prompt 5) ---
# Grace delay before observing after a remediation (ArgoCD sync time). Default: 30s.
VERIFIER_GRACE_DELAY=30s
# Total observation window after grace delay. Default: 5m.
VERIFIER_WINDOW=5m
# How often to poll the recovery source during the window. Default: 15s.
VERIFIER_POLL_INTERVAL=15s
# Max number of matching signals allowed before FAILED verdict (>threshold → FAIL). Default: 0.
VERIFIER_FAILURE_THRESHOLD=0

# --- Orchestrator (Prompt 7) ---
# Set to "true" to allow real GitOps commits. Default: false (dry-run-only).
# This is the top-level apply gate; the kill switch overrides it at runtime.
ORCHESTRATOR_APPLY_ENABLED=false
# Set to "true" to halt all remediation immediately (checked before every Apply call).
ORCHESTRATOR_KILL_SWITCH=false
# Maximum number of concurrent incident pipelines. Default: 5.
ORCHESTRATOR_MAX_WORKERS=5
# Default container name used by rollback/bump-memory when not specified in diagnosis. Default: app.
ORCHESTRATOR_DEFAULT_CONTAINER=app
# Default target replica count for scale-deployment when not specified. Default: 2.
ORCHESTRATOR_DEFAULT_SCALE_REPLICAS=2

# --- Decision / Policy (Prompt 3) ---
# Path to the policy.yaml file loaded by the decision engine.
# If unset or invalid, the engine uses fail-closed defaults (propose for all).
POLICY_FILE=./policy.yaml

# --- Audit log (Prompt 8) ---
# Set to "false" to disable the JSONL audit file entirely.
AUDIT_ENABLED=true
# Path to the append-only audit event log (JSONL format, one event per line).
AUDIT_FILE_PATH=./data/audit.jsonl

# --- Learner service (Prompt 8) ---
# Base URL of the Python learner service. Empty → outcome reporting disabled.
LEARNER_ADDR=http://localhost:8002
# Per-report HTTP timeout for the Go → learner call. Default: 5s.
LEARNER_TIMEOUT=5s
# Port the Python learner FastAPI service listens on.
LEARNER_PORT=8002
LEARNER_HOST=0.0.0.0
# Path where the learner stores outcome records (JSONL, append-only).
LEARNER_STATS_PATH=./data/outcomes.jsonl

# --- Persistent Store ---
# SQLite data source name. Default: WAL-mode file in ./data/
# The data directory is created automatically on startup.
STORE_DSN=file:./data/autosre.db?_journal_mode=WAL

# --- Web API + Auth ---
# Set to "true" to require OIDC Bearer tokens on all API requests.
# When false (default): all requests are granted viewer access (dev/staging only).
API_OIDC_ENABLED=false
# OIDC provider issuer URL (e.g. https://accounts.google.com).
# Required when API_OIDC_ENABLED=true.
API_OIDC_ISSUER_URL=
# OAuth2 client ID for audience validation.
API_OIDC_CLIENT_ID=
# JWT claim key that contains the user's roles (string or []string). Default: "roles".
API_OIDC_ROLES_CLAIM=roles
# Path to the built Web UI static files (output of: cd web-ui && npm run build).
# When empty, / returns a placeholder page with links to the API endpoints.
WEB_UI_DIR=

# --- Python services ---
PYTHON_ENV=development
